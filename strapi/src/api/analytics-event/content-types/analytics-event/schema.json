{
  "kind": "collectionType",
  "collectionName": "analytics_events",
  "info": {
    "singularName": "analytics-event",
    "pluralName": "analytics-events",
    "displayName": "Analytics Event"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "eventType": {
      "type": "enumeration",
      "enum": [
        "page_view_login",
        "page_view_register"
      ],
      "required": true
    },
    "metadata": {
      "type": "json"
    },
    "sessionId": {
      "type": "string"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
